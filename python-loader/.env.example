# Milvus connection
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=documents

# Embedding API — must match what the MCP server uses
# Supported types: ollama, openai
EMBEDDING_API_TYPE=ollama
EMBEDDING_API_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# Only needed when EMBEDDING_API_TYPE=openai
OPENAI_API_KEY=

# Path to the CSV data file
DATA_FILE_PATH=../data/sample_documents.toon
